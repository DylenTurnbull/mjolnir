#!/usr/bin/expect -f

set timeout 90
set stty_init "rows 40 columns 120"
set mode $env(MJ_E2E_MODE)
set transcript $env(MJ_E2E_TRANSCRIPT)
log_file -noappend $transcript

proc send_ctrl_c {} {
    global spawn_id
    send -i $spawn_id -- "\003"
}

set command [list $env(MJ_E2E_BIN) --no-update-check --debug-file $env(MJ_E2E_DEBUG_LOG) --agent-stderr $env(MJ_E2E_AGENT_STDERR)]
if {$mode ne "inline-stream"} {
    lappend command --fullscreen-tui
}
lappend command --cwd $env(MJ_E2E_WORKSPACE)
spawn {*}$command
if {$mode eq "inline-stream"} {
    expect_before -re {\x1b\[6n} {
        send -- "\x1b\[1;1R"
        exp_continue
    }
}

if {$mode eq "unsupported"} {
    expect {
        -re {does not support HTTP MCP servers required for code-agent delegation} { after 500 }
        timeout { exit 18 }
    }
    exit 0
}

expect {
    -re {F1 Model} { after 300; send -- "write a hello world program in Python\r" }
    timeout { exit 19 }
}

if {$mode eq "inline-stream"} {
    expect {
        -re {Eitri:.*fixture reasoning} {
            if {[file exists $env(MJ_E2E_PRIMARY_RESULT)]} { exit 25 }
            send_ctrl_c
        }
        timeout { exit 26 }
    }
    expect {
        -re {Eitri.*cancelled} { after 500; send_ctrl_c }
        timeout { exit 27 }
    }
} elseif {$mode eq "cancel"} {
    expect {
        -re {Eitri.*gpt-5-6-luna} { after 500; send_ctrl_c }
        timeout { exit 20 }
    }
    expect {
        -re {Eitri.*cancelled} { after 500; send_ctrl_c }
        timeout { exit 21 }
    }
} else {
    if {$mode eq "loki-final"} {
        expect {
            -re {Eitri permission} { send -- "\r"; exp_continue }
            -re {final verdict delivered to Thor} { after 800; send_ctrl_c }
            timeout { exit 23 }
        }
    } elseif {$mode eq "loki-thor"} {
        expect {
            -re {Eitri permission} { send -- "\r"; exp_continue }
            -re {Loki intervenes against Thor} {
                expect {
                    -re {Eitri permission} { send -- "\r"; exp_continue }
                    -re {Eitri.*complete} { after 500; send_ctrl_c }
                    timeout { exit 24 }
                }
            }
            timeout { exit 23 }
        }
    } else {
        expect {
            -re {Eitri permission} { send -- "\r"; exp_continue }
            -re {Eitri.*complete} { after 500; send_ctrl_c }
            timeout { exit 23 }
        }
    }
}
expect eof
