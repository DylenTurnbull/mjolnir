<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mjolnir third-party licenses</title>
    <style>
      @media (prefers-color-scheme: dark) {
        body { background: #333; color: white; }
        a { color: skyblue; }
      }
      .container { font-family: sans-serif; max-width: 800px; margin: 0 auto; }
      .intro { text-align: center; }
      .licenses-list { list-style-type: none; margin: 0; padding: 0; }
      .license-used-by { margin-top: -10px; }
      .license-text { max-height: 200px; overflow-y: scroll; white-space: pre-wrap; }
    </style>
  </head>
  <body>
    <main class="container">
      <div class="intro">
        <h1>Mjolnir third-party licenses</h1>
        <p>
          This report covers the locked production Rust workspace graph
          incorporated into official Mjolnir and voice-worker binaries across
          all native release targets. It is conservative: Cargo metadata can
          also contribute build packages that are not linked into an artifact.
        </p>
        <p>
          Mjolnir's own terms are in <code>LICENSE</code>.
          <code>SOURCE.md</code> identifies the corresponding source revision.
          Native libraries, embedded web fonts, standalone notices, and the
          separately packaged Anvil binary are covered by
          <code>SUPPLEMENTAL_THIRD_PARTY_NOTICES.txt</code> and the accompanying
          legal files.
        </p>
      </div>
      <h2>Overview of licenses:</h2>
      <ul class="licenses-overview">
        {{#each overview}}
          <li><a href="#{{id}}">{{name}}</a> ({{count}})</li>
        {{/each}}
      </ul>
      <h2>All license text:</h2>
      <ul class="licenses-list">
        {{#each licenses}}
          <li class="license">
            <h3 id="{{id}}">{{name}}</h3>
            <h4>Used by:</h4>
            <ul class="license-used-by">
              {{#each used_by}}
                <li><a href="https://crates.io/crates/{{crate.name}}/{{crate.version}}">{{crate.name}} {{crate.version}}</a></li>
              {{/each}}
            </ul>
            <pre class="license-text">{{text}}</pre>
          </li>
        {{/each}}
      </ul>
    </main>
  </body>
</html>
