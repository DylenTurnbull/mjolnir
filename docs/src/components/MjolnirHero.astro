---
import { LinkButton } from '@astrojs/starlight/components';
import type { StarlightRouteData } from '@astrojs/starlight/route-data';

const { data } = (Astro.locals as { starlightRoute: StarlightRouteData }).starlightRoute.entry;
const { actions = [] } = data.hero || {};

const hammerWidth = 52;
const hammerMask = `####################################################
####################################################
####################################################
##                                                ##
##    ########################################    ##
##    ##                                    ##    ##
##    ##                                    ##    ##
##    ##                                    ##    ##
##    ##                                    ##    ##
##    ########################################    ##
##                                                ##
####################################################
####################################################
####################################################
                    ############
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ##  ####  ##
                    ############
                 ##################
                 ##              ##
                 ##################`
  .split('\n')
  .map((line) => line.padEnd(hammerWidth, ' '))
  .join('\n');
const hammerGlyphs = 'AVXMWN';
const hammerArt = [...hammerMask]
  .map((cell, index) => (cell === '#' ? hammerGlyphs[(index * 7) % hammerGlyphs.length] : cell))
  .join('');

const councilTopology = `              THOR / DIRECTOR
        plan · route · synthesize
                    │
             ┌──────┴──────┐
             ▼             ▼
       EITRI / FORGE   LOKI / REVIEW
       isolate · build  inspect · challenge
             │             │
             └──────┬──────┘
                    ▼
             COUNCIL / READY`;
---

<section class="mj-hero" aria-labelledby="_top">
  <div class="hero-copy">
    <div class="hero-hammer" aria-hidden="true">
      <pre class="hammer-art" data-hammer-art data-mask={hammerMask}><code>{hammerArt}</code></pre>
    </div>
    <p class="hero-kicker"><span aria-hidden="true">⚡</span> MJOLNIR / NATIVE RUST TUI</p>
    <h1 id="_top">One terminal.<br /><em>A council</em> of agents.</h1>
    <p class="hero-tagline">Mjolnir gives coding agents distinct roles, a shared terminal, and one consistent way to work—no matter which model is behind the hammer.</p>
    {
      actions.length > 0 && (
        <div class="hero-actions">
          {actions.map(({ icon, link: href, text, variant }) => (
            <LinkButton href={href} variant={variant} icon={icon?.name}>
              {text}
              {icon?.html && <Fragment set:html={icon.html} />}
            </LinkButton>
          ))}
        </div>
      )
    }
    <ul class="hero-facts" aria-label="Council roles">
      <li><span>01 / THOR</span><strong>Directs the work</strong></li>
      <li><span>02 / EITRI</span><strong>Forges the change</strong></li>
      <li><span>03 / LOKI</span><strong>Tests the thinking</strong></li>
    </ul>
  </div>

  <div class="storm-console" aria-label="Example Mjolnir council session">
    <div class="console-bar">
      <span><i></i> COUNCIL / SESSION 0042</span>
      <small>RAGNAROK: STANDBY</small>
    </div>
    <div class="ascii-storm" aria-hidden="true">
      <pre class="council-topology"><code>{councilTopology}</code></pre>
    </div>
    <div class="council-feed">
      <div><b>THOR</b><span>plans the turn and delegates the seam</span><small>COORDINATING</small></div>
      <div><b>EITRI</b><span>implements in a fresh agent context</span><small>FORGING</small></div>
      <div><b>LOKI</b><span>reviews checkpoints without blocking progress</span><small>OBSERVING</small></div>
    </div>
    <div class="console-prompt"><span>❯</span><code>mj --worktree quiet-forge</code><i></i></div>
  </div>

  <p class="hero-rail" aria-hidden="true">MODEL FIRST // ACP NATIVE // INLINE TUI // COUNCIL CONTROL</p>
</section>

<script>
  const animateHammers = () => {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    document.querySelectorAll<HTMLElement>('[data-hammer-art]').forEach((art) => {
      const code = art.querySelector('code');
      const mask = art.dataset.mask;
      if (!code || !mask || reducedMotion.matches || art.dataset.animated === 'true') return;

      art.dataset.animated = 'true';
      const glyphs = 'AVXMWN';
      const cells = [...code.textContent!];
      const interval = window.setInterval(() => {
        if (!code.isConnected || reducedMotion.matches) {
          window.clearInterval(interval);
          return;
        }

        for (let index = 0; index < cells.length; index += 1) {
          if (mask[index] === '#' && Math.random() < 0.24) {
            cells[index] = glyphs[Math.floor(Math.random() * glyphs.length)];
          }
        }
        code.textContent = cells.join('');
      }, 90);
    });
  };

  animateHammers();
  document.addEventListener('astro:page-load', animateHammers);
</script>

<style>
  @layer starlight.user {
    .mj-hero {
      position: relative;
      isolation: isolate;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: clamp(3rem, 5vw, 5rem);
      align-items: center;
      min-height: min(50rem, calc(100vh - var(--sl-nav-height)));
      padding: clamp(4.5rem, 8vw, 7.5rem) clamp(0rem, 2vw, 1.7rem) clamp(7rem, 11vw, 9rem);
      overflow: hidden;
    }
    .mj-hero::before {
      position: absolute;
      z-index: -2;
      inset: 0 -50vw;
      background:
        linear-gradient(90deg, transparent 49.8%, var(--mj-grid-strong) 50%, transparent 50.2%),
        linear-gradient(transparent 49.8%, var(--mj-grid-strong) 50%, transparent 50.2%);
      background-size: 7rem 7rem;
      content: '';
      mask-image: linear-gradient(180deg, black 15%, transparent 94%);
    }
    .mj-hero::after {
      position: absolute;
      z-index: -1;
      inset: 6% -2% auto auto;
      width: min(52vw, 48rem);
      height: min(52vw, 48rem);
      background: radial-gradient(circle, color-mix(in srgb, var(--mj-violet) 17%, transparent), transparent 64%);
      content: '';
      filter: blur(12px);
    }

    .hero-copy { position: relative; z-index: 2; max-width: none; }
    .hero-hammer {
      position: absolute;
      z-index: -1;
      inset: 1rem -2rem auto auto;
      display: block;
      width: 32rem;
      padding: 0;
      background: radial-gradient(ellipse at 54% 45%, color-mix(in srgb, var(--mj-violet) 18%, transparent), transparent 68%);
      color: var(--mj-violet-soft);
      font-family: var(--sl-font-mono);
      filter: drop-shadow(0 0 24px color-mix(in srgb, var(--mj-violet) 26%, transparent));
      mask-image: radial-gradient(ellipse 82% 84% at 52% 46%, black 56%, rgb(0 0 0 / 0.68) 80%, transparent 100%);
      opacity: 0.32;
      pointer-events: none;
    }
    .hammer-art {
      position: relative;
      z-index: 1;
      width: 52ch;
      margin: 0;
      padding: 0;
      border: 0;
      background: transparent;
      color: inherit;
      font-size: 0.9rem;
      font-weight: 650;
      letter-spacing: 0;
      line-height: 1.04;
      text-align: left;
      text-shadow: 0 0 12px color-mix(in srgb, var(--mj-violet) 48%, transparent);
      white-space: pre;
    }
    .hammer-art code { background: transparent; color: inherit; font: inherit; letter-spacing: inherit; }
    .hero-kicker {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 0 0 1.5rem;
      color: var(--mj-muted);
      font-family: var(--sl-font-mono);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
    }
    .hero-kicker span { color: var(--mj-gold); text-shadow: 0 0 14px color-mix(in srgb, var(--mj-gold) 75%, transparent); }

    .mj-hero h1 {
      max-width: 12ch;
      margin: 0;
      color: var(--mj-ink);
      font-family: var(--mj-display);
      font-size: clamp(4rem, 7.5vw, 7.7rem);
      font-weight: 760;
      letter-spacing: -0.065em;
      line-height: 0.82;
    }
    .mj-hero h1 em { color: var(--mj-violet); font-style: normal; text-shadow: 0 0 34px color-mix(in srgb, var(--mj-violet) 18%, transparent); }
    .hero-tagline { max-width: 40rem; margin: 2rem 0 0; color: var(--mj-copy); font-size: clamp(1.06rem, 1.45vw, 1.23rem); line-height: 1.58; }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 2rem; }
    .hero-actions :global(.sl-link-button) {
      min-width: 10rem;
      justify-content: center;
      border-radius: 0.16rem;
      font-family: var(--sl-font-mono);
      font-size: 0.69rem;
      font-weight: 750;
      letter-spacing: 0.055em;
      text-transform: uppercase;
    }
    .hero-actions :global(.primary) { box-shadow: 0 10px 34px color-mix(in srgb, var(--mj-violet) 24%, transparent); }

    .hero-facts {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      max-width: 40rem;
      margin: 3rem 0 0;
      padding: 0;
      border-block: 1px solid var(--mj-line);
      list-style: none;
    }
    .hero-facts li { padding: 0.9rem 0.7rem 0.9rem 0; }
    .hero-facts li + li { padding-inline-start: 0.9rem; border-inline-start: 1px solid var(--mj-line); }
    .hero-facts span, .hero-facts strong { display: block; }
    .hero-facts span { margin-bottom: 0.22rem; color: var(--mj-violet); font-family: var(--sl-font-mono); font-size: 0.56rem; letter-spacing: 0.07em; }
    .hero-facts strong { color: var(--mj-ink); font-size: 0.77rem; font-weight: 680; }

    .storm-console {
      position: relative;
      z-index: 2;
      border: 1px solid var(--mj-line-strong);
      background:
        linear-gradient(var(--mj-grid) 1px, transparent 1px),
        linear-gradient(90deg, var(--mj-grid) 1px, transparent 1px),
        color-mix(in srgb, var(--mj-surface-raised) 94%, transparent);
      background-size: 20px 20px;
      box-shadow: 0 38px 100px rgb(0 0 0 / 0.38), inset 0 1px var(--mj-highlight);
      font-family: var(--sl-font-mono);
      width: min(100%, 54rem);
      justify-self: center;
      transform: none;
    }
    .storm-console::before, .storm-console::after {
      position: absolute;
      z-index: -1;
      width: 7rem;
      height: 7rem;
      border-color: var(--mj-violet);
      content: '';
      opacity: 0.55;
    }
    .storm-console::before { inset: -0.75rem auto auto -0.75rem; border-block-start: 1px solid; border-inline-start: 1px solid; }
    .storm-console::after { inset: auto -0.75rem -0.75rem auto; border-block-end: 1px solid; border-inline-end: 1px solid; }
    .console-bar { display: flex; justify-content: space-between; padding: 0.8rem 0.95rem; border-bottom: 1px solid var(--mj-line-strong); color: var(--mj-muted); font-size: 0.57rem; font-weight: 700; letter-spacing: 0.07em; }
    .console-bar i { display: inline-block; width: 0.42rem; height: 0.42rem; margin-right: 0.4rem; border-radius: 50%; background: var(--mj-violet); box-shadow: 0 0 11px var(--mj-violet); }
    .console-bar small { color: var(--mj-gold); font-size: inherit; }
    .ascii-storm { min-height: 18rem; display: grid; place-items: center; padding: 1.15rem 0.75rem; overflow: hidden; background: radial-gradient(circle, color-mix(in srgb, var(--mj-violet) 10%, transparent), transparent 62%); }
    .council-topology { margin: 0; padding: 0; border: 0; background: transparent; color: var(--mj-violet-soft); font-size: clamp(0.48rem, 1vw, 0.68rem); line-height: 1.65; text-shadow: 0 0 10px color-mix(in srgb, var(--mj-violet) 24%, transparent); }
    .council-topology code { background: transparent; color: inherit; }
    .council-feed { border-block: 1px solid var(--mj-line-strong); }
    .council-feed > div { display: grid; grid-template-columns: 3.4rem 1fr auto; gap: 0.7rem; align-items: center; padding: 0.68rem 0.85rem; }
    .council-feed > div + div { border-top: 1px solid var(--mj-line); }
    .council-feed b { color: var(--mj-violet); font-size: 0.6rem; letter-spacing: 0.08em; }
    .council-feed span { color: var(--mj-copy); font-size: 0.61rem; }
    .council-feed small { color: var(--mj-muted); font-size: 0.5rem; letter-spacing: 0.07em; }
    .console-prompt { display: flex; align-items: center; gap: 0.65rem; padding: 0.85rem; color: var(--mj-copy); font-size: 0.66rem; }
    .console-prompt span { color: var(--mj-gold); }
    .console-prompt i { width: 0.48rem; height: 0.9rem; background: var(--mj-violet); animation: cursor-pulse 1.1s steps(2, jump-none) infinite; }
    .hero-rail { position: absolute; inset: auto 0 1.15rem; margin: 0; color: var(--mj-muted); font-family: var(--sl-font-mono); font-size: 0.54rem; letter-spacing: 0.18em; text-align: center; }

    @keyframes cursor-pulse { 50% { opacity: 0.2; } }
    @media (max-width: 68rem) {
      .storm-console { width: min(100%, 43rem); }
    }
    @media (max-width: 48rem) { .hero-hammer { display: none; } }
    @media (max-width: 42rem) {
      .mj-hero { padding-top: 3.5rem; }
      .mj-hero h1 { font-size: clamp(3.4rem, 18vw, 5.5rem); }
      .hero-facts { grid-template-columns: 1fr; }
      .hero-facts li + li { padding-inline-start: 0; border-inline-start: 0; border-top: 1px solid var(--mj-line); }
      .ascii-storm { min-height: 14rem; }
      .ascii-storm pre { font-size: clamp(0.43rem, 2.5vw, 0.62rem); }
      .council-feed > div { grid-template-columns: 3.2rem 1fr; }
      .council-feed small { display: none; }
    }
    @media (prefers-reduced-motion: reduce) {
      .console-prompt i { animation: none; }
    }
  }
</style>
